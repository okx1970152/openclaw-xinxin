{
  "app": {
    "name": "超级大龙虾",
    "version": "3.0.0",
    "description": "智能 AI 助理系统"
  },
  "commands": {
    "create_agent": {
      "command": "创建代理",
      "description": "创建新的子代理",
      "params": {
        "template": "模板ID（可选）",
        "domain": "专业领域（可选）"
      },
      "success": "代理创建成功：{agentId}",
      "error": "代理创建失败：{reason}"
    },
    "refine_memory": {
      "command": "提练记忆",
      "description": "将临时记忆提练为永久记忆",
      "success": "记忆提练完成，新增 {count} 条永久记忆",
      "error": "记忆提练失败：{reason}"
    },
    "show_status": {
      "command": "查看状态",
      "description": "查看系统状态和代理列表",
      "format": {
        "total_agents": "总代理数",
        "active_agents": "活跃代理",
        "queue_size": "队列任务数",
        "token_usage": "Token 使用量"
      }
    },
    "rebuild_index": {
      "command": "重建索引",
      "description": "重建检索索引",
      "success": "索引重建完成，共 {count} 个文件",
      "error": "索引重建失败：{reason}"
    },
    "install_skill": {
      "command": "安装Skill",
      "description": "安装新的技能模块",
      "params": {
        "skill_path": "Skill 路径或URL"
      },
      "success": "Skill 安装成功：{skillName}",
      "error": "Skill 安装失败：{reason}",
      "security_warning": "安全警告：{findings}"
    },
    "retry_refine": {
      "command": "重新提练",
      "description": "从备份重新提练记忆",
      "success": "重新提练完成",
      "error": "重新提练失败：{reason}"
    },
    "clone_agent": {
      "command": "克隆代理",
      "description": "克隆现有代理",
      "params": {
        "source_agent_id": "源代理ID"
      },
      "success": "代理克隆成功：{newAgentId}",
      "error": "代理克隆失败：{reason}"
    },
    "destroy_agent": {
      "command": "销毁代理",
      "description": "销毁指定的代理",
      "params": {
        "agent_id": "代理ID"
      },
      "confirm": "确定要销毁代理 {agentId} 吗？此操作不可恢复。",
      "success": "代理已销毁：{agentId}",
      "error": "代理销毁失败：{reason}"
    },
    "hibernate_agent": {
      "command": "休眠代理",
      "description": "将代理休眠以节省资源",
      "success": "代理已休眠：{agentId}",
      "error": "代理休眠失败：{reason}"
    },
    "activate_agent": {
      "command": "激活代理",
      "description": "唤醒休眠的代理",
      "success": "代理已激活：{agentId}",
      "error": "代理激活失败：{reason}"
    },
    "export_patterns": {
      "command": "导出模式",
      "description": "导出任务模式库",
      "success": "已导出 {count} 个任务模式"
    },
    "import_patterns": {
      "command": "导入模式",
      "description": "导入任务模式库",
      "success": "已导入 {count} 个任务模式",
      "error": "模式导入失败：{reason}"
    }
  },
  "status": {
    "agent": {
